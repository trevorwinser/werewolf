function w:config/display/button {Pos:"29 2.8 -3.0",rotation:90,text:"⬅",color:"white",scale:4,command:"function w:config/section/roles/edit/load",sound:"minecraft:block.wooden_button.click_on"}
function w:config/display/add_or_remove {Pos:"29 2 0",rotation:90,text:"Any (Town)",path:"role.anytown",max:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",min:"score role.anytown storage matches 1.."}
function w:config/display/toggle {Pos:"29 1.2 -4",rotation:90,text:"Mayor",path:"role.mayor",id:"paper",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",off:"entity @s",info:"Mayor\nAbilities:\nAccrue votes by abstaining from votes during the day. Each vote abstained is a vote gained.\nReveal yourself as Mayor during the day to use your accrued votes.\nAttributes:\nYour votes will appear as if you voted only once.\nGoal:\nEliminate all evildoers and all who oppose the Town.\n"}
function w:config/display/toggle {Pos:"29 1 -3",rotation:90,text:"Sheriff",path:"role.sheriff",id:"bow",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",off:"entity @s",info:"Sheriff\nAbilities:\nDecide between investigating and eliminating a player at night.\nAttributes:\nYou can only attempt to eliminate players 3 times.\nIf the player you eliminate is part of the Town, you will be eliminated as well.\nGoal:\nEliminate all evildoers and all who oppose the Town.\n"}
function w:config/display/toggle {Pos:"29 1.2 -2",rotation:90,text:"Deputy",path:"role.deputy",id:"crossbow",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",off:"entity @s",info:"Deputy\nAbilities:\nInvestigate a player at night for susipicious activity.\nAttributes:\nIf the Sheriff is eliminated, you will become the new Sheriff.\nGoal:\nEliminate all evildoers and all who oppose the Town.\n\n\n"}
function w:config/display/toggle {Pos:"29 1 -1",rotation:90,text:"Detective",path:"role.detective",id:"spyglass",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",off:"entity @s",info:"Detective\nAbilities:\nInvestigate a player at night to get a clue about their role.\nAttributes:\nNone.\nGoal:\nEliminate all evildoers and all who oppose the Town.\n\n\n"}
function w:config/display/toggle {Pos:"29 1.2 0",rotation:90,text:"Medic",path:"role.medic",id:"golden_apple",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",off:"entity @s",info:"Medic\nAbilities:\nVisit a player at night to heal them. If they are attacked they will be saved.\nAttributes:\nOnly your target will know if they were attacked.\nGoal:\nEliminate all evildoers and all who oppose the Town.\n\n"}
function w:config/display/toggle {Pos:"29 1 1",rotation:90,text:"Scout",path:"role.scout",id:"sugar",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",off:"entity @s",info:"Scout\nAbilities:\nVisit a player at night to witness who visits them.\nAttributes:\nIf the player you visit is eliminated, the player who eliminated them will be aware that they were witnessed.\nGoal:\nEliminate all evildoers and all who oppose the Town.\n\n"}
function w:config/display/toggle {Pos:"29 1.2 2",rotation:90,text:"Veteran",path:"role.veteran",id:"iron_sword",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",off:"entity @s",info:"Veteran\nAbilities:\nDecide whether you will be alert at night.\nAttributes:\nYou cannot be harmed while alert.\nAnyone who visits you while you are alert will be eliminated.\nYou can only be alert 3 times.\nGoal:\nEliminate all evildoers and all who oppose the Town.\n"}
function w:config/display/toggle {Pos:"29 1 3",rotation:90,text:"Deflector",path:"role.deflector",id:"glass",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",off:"entity @s",info:"Deflector\nAbilities:\nDeflect the action of a player at night onto another player.\nAttributes:\nYou can only deflect targetable actions.\nYour target will know their action has been deflected.\nGoal:\nEliminate all evildoers and all who oppose the Town.\n\n"}
function w:config/display/toggle {Pos:"29 1.2 4",rotation:90,text:"Swapper",path:"role.swapper",id:"ender_pearl",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.townamount storage matches ..8",off:"entity @s",info:"Swapper\nAbilities:\nSwap two players at night.\nAttributes:\nAll actions targeting the two players will be swapped.\nGoal:\nEliminate all evildoers and all who oppose the Town.\n\n\n"}

