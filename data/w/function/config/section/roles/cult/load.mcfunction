function w:config/display/toggle {Pos:"29 1.2 -2",rotation:90,text:"Cult Leader",path:"role.cultleader",id:"enderman_spawn_egg",big:0.7,small:0.5,on1:"score role.amount storage matches ..10",on2:"score role.cultamount storage < role.cultamount max",onmessage:"You cannot add more roles!",off1:"entity @s",off2:"entity @s",offmessage:"",info:"Cult Leader\nAbilities:\nDecide between initiating a player and killing a player each night.\nAttributes:\nIf there is an Acolyte, they will kill in your place.\nDeceiving a player provides them with faulty information for that night.\nGoal:\nKill or deceive all who do not follow the Cult."}
function w:config/display/toggle {Pos:"29 1 -1",rotation:90,text:"Acolyte",path:"role.acolyte",id:"endermite_spawn_egg",big:0.7,small:0.5,on1:"score role.amount storage matches ..10",on2:"score role.cultamount storage < role.cultamount max",onmessage:"You cannot add more roles!",off1:"entity @s",off2:"entity @s",offmessage:"",info:"Acolyte\nAbilities:\nKill a player each night.\nAttributes:\nYou can decide who to kill if the cult leader does not decide for you.\nIf the Cult Leader is killed, you will become the new Cult Leader.\nGoal:\nKill or deceive all who do not follow the Cult."}
function w:config/display/toggle {Pos:"29 1.2 0",rotation:90,text:"Initiate",path:"role.initiate",id:"leather_helmet",big:0.7,small:0.5,on1:"score role.amount storage matches ..10",on2:"score role.cultamount storage < role.cultamount max",onmessage:"You cannot add more roles!",off1:"entity @s",off2:"entity @s",offmessage:"",info:"Initiate\nAbilities:\nLearn the ways of the Cult.\nAttributes:\nIf there is no Fall Guy or Manipulator, you will become one the next night.\nGoal:\nKill or deceive all who do not follow the Cult.\n\n"}
function w:config/display/toggle {Pos:"29 1 1",rotation:90,text:"Manipulator",path:"role.manipulator",id:"pink_glazed_terracotta",big:0.5,small:0.3,on1:"score role.amount storage matches ..10",on2:"score role.cultamount storage < role.cultamount max",onmessage:"You cannot add more roles!",off1:"entity @s",off2:"entity @s",offmessage:"",info:"Manipulator\nAbilities:\nManipulate two players at night to act on each other.\nAttributes:\nYou can only manipulate targetable actions.\nYour target will know their action has been manipulated.\nIf there is no Acolyte, you will become one the next night.\nGoal:\nKill or deceive all who do not follow the Cult.\n"}
function w:config/display/toggle {Pos:"29 1.2 2",rotation:90,text:"Fall Guy",path:"role.fallguy",id:"light_blue_harness",big:0.7,small:0.5,on1:"score role.amount storage matches ..10",on2:"score role.cultamount storage < role.cultamount max",onmessage:"You cannot add more roles!",off1:"entity @s",off2:"entity @s",offmessage:"",info:"Fall Guy\nAbilities:\nAttempt to take the place of a fellow Cult member at night.\nAttributes:\nAny action done onto your selected fellow will be put onto you.\nSuccess rate starts at 50%; each success −25%, each failure +25%\nIf there is no Acolyte, you will become one the next night.\nGoal:\nKill or deceive all who do not follow the Cult."}