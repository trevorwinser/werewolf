function w:config/reset
function w:config/display/text {Pos:"29 3 0",rotation:90,alignment:"center",text:"Cult",color:white,scale:2}
function w:config/display/button {Pos:"29 2.8 -3.0",rotation:90,text:"⬅",color:"white",scale:4,command:"function w:config/section/roles/edit/load",sound:"minecraft:block.wooden_button.click_on"}

function w:config/display/add_or_remove {Pos:"29 2 0",rotation:90,text:"Any (Cult)",path:"role.anycult",max:"score role.amount storage matches ..10 if score role.cultamount storage matches ..4",min:"score role.anycult storage matches 1.."}
function w:config/display/toggle {Pos:"29 1.2 -2",rotation:90,text:"Cult Leader",path:"role.cultleader",id:"enderman_spawn_egg",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.cultamount storage matches ..4",off:"entity @s",info:"Cult Leader\nAbilities:\nDecide between initiating a player and killing a player each night.\nAttributes:\nIf there is an Initiate, you may not initiate a new player.\nIf there is an Acolyte, they will kill in your place.\nGoal:\nIndoctrinate or kill all who do not follow the Cult.\n"}
function w:config/display/toggle {Pos:"29 1 -1",rotation:90,text:"Acolyte",path:"role.acolyte",id:"endermite_spawn_egg",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.cultamount storage matches ..4",off:"entity @s",info:"Acolyte\nAbilities:\nKill a player each night.\nAttributes:\nYou can decide who to kill if the cult leader does not decide for you.\nIf the Cult Leader is killed, you will become the new Cult Leader.\nGoal:\nIndoctrinate or kill all who do not follow the Cult."}
function w:config/display/toggle {Pos:"29 1.2 0",rotation:90,text:"Initiate",path:"role.initiate",id:"leather_helmet",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.cultamount storage matches ..4",off:"entity @s",info:"Initiate\nAbilities:\nNone.\nAttributes:\nIf the Acolyte is killed or becomes the Cult Leader, you will become the new Acolyte.\nGoal:\nIndoctrinate or kill all who do not follow the Cult.\n\n"}
function w:config/display/toggle {Pos:"29 1 1",rotation:90,text:"Manipulator",path:"role.manipulator",id:"pink_glazed_terracotta",big:0.5,small:0.3,on:"score role.amount storage matches ..10 if score role.cultamount storage matches ..4",off:"entity @s",info:"Manipulator\nAbilities:\nManipulate two players at night to act on each other.\nAttributes:\nYou can only manipulate targetable actions.\nYour target will know their action has been manipulated.\nGoal:\nIndoctrinate or kill all who do not follow the Cult.\n\n"}
function w:config/display/toggle {Pos:"29 1.2 2",rotation:90,text:"Fall Guy",path:"role.fallguy",id:"light_blue_harness",big:0.7,small:0.5,on:"score role.amount storage matches ..10 if score role.cultamount storage matches ..4",off:"entity @s",info:"Fall Guy\nAbilities:\nTake the place of a fellow cult members at night.\nAttributes:\nAny action done onto your selected fellow will be put onto you.\nYour action starts at a 50% success rate.\nEach night you succeed it drops by 25% and each night you fail it increases by 25%.\nGoal:\nIndoctrinate or kill all who do not follow the Cult."}